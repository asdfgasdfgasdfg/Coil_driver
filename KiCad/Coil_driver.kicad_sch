		(uuid "3e63445b-f8b5-4528-a7f5-02fca3db0be1")
	)
	(text "HIP4080A start-up circuit, following requirements from datasheet.\nHas some open connections (A, B, C...) that I'll use to test if I\ncan get away with a simpler circuit."
		(exclude_from_sim no)
		(at 64.262 134.366 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "70878da3-3fa8-4ce0-b941-e1239b2fdee8")
	)
	(text "NMOS H-bridge, 6A max drain current"
		(exclude_from_sim no)
		(at 171.45 54.356 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8f3e662b-5251-42f5-9b23-ab949189d35f")
	)
	(text "USB C power input"
		(exclude_from_sim no)
		(at 33.274 144.526 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a03d6d6e-8d18-42cf-b1aa-756e1effc7e4")
	)
	(text "Overcurrent protection:\nMax current threshold can be set using R23 & R24.\nIf current is higher than the threshold, the opamp\npulls both lower h-bridge gates low (AL, BL). \nMight need to add some hysterisis or stickyness to prevent\nopamp from half-closing the lower mosfets rather than fully shutting\nthem down, as this can damage the mosfets."
		(exclude_from_sim no)
		(at 233.934 127.762 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "abd9b3d0-cdbe-4cf3-9522-6df3c6cd7e70")
	)
	(text "Optocoupler so 5V En input can drive 15V logic"
		(exclude_from_sim no)
		(at 34.544 106.172 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ae4b73f2-1423-4559-82ab-484ea4daa601")
	)
	(text "Coil-kickback can cause Vsense to go below GND.\nD4 shottky keeps Vsense > GND-0.6V."
		(exclude_from_sim no)
		(at 142.24 99.568 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ae7b16d2-149a-4a58-861e-b398481e9d95")
	)
	(text "Mistake -- Vsense should be the amplified one, \nso I'll just have to tap the amplified one with a wire."
		(exclude_from_sim no)
		(at 246.634 67.31 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c514a443-7bd6-4b87-932e-42feddedcba8")
	)
	(text "Amplify Vsense, so 5A -> 0.5V Vsense -> x6 gain = 3V.\n"
		(exclude_from_sim no)
		(at 217.678 84.582 0)
		(effects
